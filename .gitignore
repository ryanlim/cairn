.env
.env.*
!.env.example
.build/
.swiftpm/
*.xcodeproj
DerivedData/
.DS_Store

# Local persistence for the CLI
ever-seen.json
deletion-journal.jsonl
exclusions.json
cairn-settings.json

# Per-machine Claude Code permissions (the "local" suffix is the convention)
.claude/settings.local.json

# Claude Code session/agent runtime state — local-only, regenerated per session
.claude/

# App Store reviewer-demo Immich setup. Contains shell scripts that bake
# in domain assumptions plus demo image assets. Kept local so the public
# repo doesn't expose review-instance details. Leading slash scopes the
# rule to the repo-root scripts/ — `iOS/scripts/` (capture-screenshots,
# export-wordmark, etc.) is shipping tooling and stays tracked.
/scripts/

# iOS app target — generated by XcodeGen from iOS/project.yml; never committed.
iOS/Cairn.xcodeproj/
iOS/build/
iOS/vendor/
iOS/.bundle/
iOS/fastlane/report.xml
iOS/fastlane/test_output/
iOS/fastlane/screenshots/
iOS/fastlane/metadata/
*.ipa
*.dSYM.zip
*.xcresult
# Per-developer Apple Developer Team ID — see iOS/README.md "Running on a real device".
iOS/.team
# Per-developer Immich dev credentials seeded by `make device` on debug installs.
iOS/.dev-secrets
