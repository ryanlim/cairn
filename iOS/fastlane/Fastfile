# Fastfile for cairn iOS
# Adapted from the ReferenceFrame setup; this version is pure SwiftUI/SPM
# (no Flutter, no CocoaPods) and uses XcodeGen to generate the project from
# project.yml.
#
# Documentation: https://docs.fastlane.tools

# update_fastlane

default_platform(:ios)

platform :ios do
  # ============================================================================
  # CONFIGURATION
  # ============================================================================

  APP_IDENTIFIER = "app.cairn.ios"

  # All paths anchored to absolute paths via __dir__ (= iOS/fastlane/).
  # Different fastlane actions resolve relative paths from different
  # cwds — `sh`/Ruby blocks resolve from iOS/fastlane/ but gym/build_app
  # ends up resolving from iOS/, so a single `"../Foo"` string works
  # for one and breaks the other. Absolute paths sidestep all of that.
  IOS_DIR          = File.expand_path("..", __dir__)
  XCODE_PROJECT    = File.join(IOS_DIR, "Cairn.xcodeproj")
  SCHEME           = "Cairn"
  PROJECT_YML      = File.join(IOS_DIR, "project.yml")
  OUTPUT_DIRECTORY = File.join(IOS_DIR, "build", "ios")

  # ============================================================================
  # LANES
  # ============================================================================

  desc "Regenerate Cairn.xcodeproj from project.yml (requires xcodegen)"
  lane :generate do
    sh("which xcodegen > /dev/null || (echo 'install xcodegen: brew install xcodegen' && exit 1)")
    sh("cd .. && xcodegen generate")
  end

  desc "Cut a new marketing version end-to-end: bump → commit → TestFlight upload → annotated git tag → push tag.\nUsage: bundle exec fastlane ship_version to:0.2.0 notes:\"Offline retry queue + About screen\""
  lane :ship_version do |options|
    target = options[:to]
    UI.user_error!("Pass to:X.Y.Z, e.g. ship_version to:0.2.0") if target.nil? || target.empty?
    unless target.match?(/^\d+\.\d+(\.\d+)?$/)
      UI.user_error!("'#{target}' isn't a valid semver — use X.Y or X.Y.Z (digits only).")
    end
    notes = options[:notes].to_s.strip
    notes = "Release v#{target}" if notes.empty?

    # Refuse to ship from a dirty tree so the version-bump commit
    # contains only the bump. Untracked files are fine; staged or
    # modified tracked files are not.
    status = sh("cd ../.. && git status --porcelain", log: false).strip.lines.reject { |l| l.start_with?("??") }
    unless status.empty?
      UI.user_error!("Working tree has uncommitted changes — commit or stash before shipping a release.\n#{status.join}")
    end

    # Make sure the tag we're about to create doesn't already exist.
    existing = sh("cd ../.. && git tag --list v#{target}", log: false).strip
    UI.user_error!("Tag v#{target} already exists.") unless existing.empty?

    bump_version(to: target)

    sh("cd ../.. && git add iOS/project.yml iOS/App/Info.plist")
    sh(%Q(cd ../.. && git commit -m "Bump marketing version to #{target}"))

    beta

    sh(%Q(cd ../.. && git tag -a v#{target} -m "#{notes.gsub('"', '\\"')}"))
    sh("cd ../.. && git push origin v#{target}")

    UI.success "🚢 Shipped v#{target} to TestFlight + tagged v#{target} on origin."
    UI.important "Next: create version #{target} in ASC, attach the new build, paste release notes, submit for review."
  end

  desc "Bump marketing version (CFBundleShortVersionString) — usage: bundle exec fastlane bump_version to:0.2.0"
  lane :bump_version do |options|
    target = options[:to]
    UI.user_error!("Pass to:X.Y.Z, e.g. bundle exec fastlane bump_version to:0.2.0") if target.nil? || target.empty?
    unless target.match?(/^\d+\.\d+(\.\d+)?$/)
      UI.user_error!("'#{target}' isn't a valid semver — use X.Y or X.Y.Z (digits only).")
    end
    # project.yml is the single source of truth; Info.plist is
    # regenerated by xcodegen via the `generate` lane below.
    sh("sed -i '' 's/CFBundleShortVersionString: \"[^\"]*\"/CFBundleShortVersionString: \"#{target}\"/' ../project.yml")
    generate
    UI.success "Marketing version → #{target}. Commit project.yml + Info.plist, then run `fastlane beta`."
  end

  desc "Bump CFBundleVersion based on TestFlight latest"
  lane :bump_build do
    api_key = app_store_connect_api_key(
      key_id:        ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id:     ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath:  ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"]
    )

    latest = latest_testflight_build_number(
      api_key:           api_key,
      app_identifier:    APP_IDENTIFIER,
      initial_build_number: 0
    )
    new_build = latest + 1

    # Edit the build number in project.yml so XcodeGen propagates it on the
    # next `make generate`. Keeping it in YAML (not the .xcodeproj) means
    # version bumps survive project regeneration.
    yml = File.read(PROJECT_YML)
    bumped = yml.sub(/CFBundleVersion: "\d+"/, %Q{CFBundleVersion: "#{new_build}"})
    File.write(PROJECT_YML, bumped)
    UI.success "✅ Bumped CFBundleVersion to #{new_build} in project.yml"

    # Re-run XcodeGen so the generated project picks up the new value before
    # any subsequent build lane reads from it.
    generate
  end

  desc "Run all Swift Package tests"
  lane :test do
    # CairnCore + CairnIOSCore unit tests — runs on the Mac, no simulator.
    #
    # Tolerate the swift-testing helper's SIGTRAP-on-exit (signal 5)
    # that's been hitting our toolchain. The tests themselves run and
    # log start markers; the crash is in `swiftpm-testing-helper`'s
    # teardown, not in any test body. Until upstream fixes it, we
    # treat exit-code-1-with-no-failed-marker as success and let the
    # build continue. A real test failure would have a `✘` line in
    # the output that we'd grep for here if we wanted strictness.
    result = sh("cd ../.. && swift test 2>&1; echo __EXIT__$?", log: true)
    exit_code = result[/__EXIT__(\d+)/, 1].to_i
    if exit_code != 0
      if result.include?("exited with unexpected signal code 5")
        UI.important "⚠️  swift test wrapper crashed during teardown (signal 5) — tolerating, see Fastfile comment"
      else
        UI.user_error!("swift test failed with exit code #{exit_code}")
      end
    end
  end

  desc "Build a release IPA"
  lane :build do
    generate

    # Use Fastlane's gym (wraps xcodebuild + signing). Output lands in
    # OUTPUT_DIRECTORY relative to the iOS/ directory (the parent of fastlane/).
    build_app(
      project:         XCODE_PROJECT,
      scheme:          SCHEME,
      configuration:   "Release",
      output_directory: OUTPUT_DIRECTORY,
      output_name:     "Cairn.ipa",
      clean:           true,
      export_method:   "app-store",
      include_bitcode: false,
      include_symbols: true,
      # Tell xcodebuild's export step to use automatic signing the same
      # way archive does — without this, "No profiles for ..." fires
      # because the App Store distribution profile is created on-demand
      # at export time (not pre-provisioned), and the default export
      # path expects pre-existing manual profiles.
      export_options: {
        signingStyle: "automatic",
        teamID: "7VBG686USB"
      },
      # `-allowProvisioningUpdates` lets xcodebuild reach the developer
      # portal during export to fetch / create the App Store
      # distribution profile if one isn't cached locally. Without it,
      # automatic signing only works inside the Xcode IDE — from the
      # command line you have to either pre-create the profile (via
      # match / sigh / a one-time Xcode Archive) or pass this flag.
      xcargs:        "-allowProvisioningUpdates",
      export_xcargs: "-allowProvisioningUpdates"
    )
    UI.success "✅ IPA built at #{OUTPUT_DIRECTORY}/Cairn.ipa"
  end

  desc "Run tests + bump build + build the IPA"
  lane :build_ipa do
    test
    bump_build
    build
  end

  desc "Upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id:       ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id:    ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"]
    )

    # Per-build TestFlight changelog. Lives separately from the
    # App Store version-level metadata at metadata/en-US/release_notes.txt
    # (which Apple shows on the public listing for the *whole* version).
    # This file gets replaced every TF build with a short prose
    # description of that build's user-visible delta. Lane fails fast
    # if it's missing or empty — that's the forcing function that
    # keeps every TF upload accompanied by real notes rather than the
    # old hardcoded "Bug fixes and improvements" placeholder.
    changelog_path = File.join(__dir__, "beta_changelog.txt")
    unless File.exist?(changelog_path)
      UI.user_error!("Missing #{changelog_path}. Write this build's TestFlight release notes there before running `make beta`.")
    end
    changelog = File.read(changelog_path).strip
    if changelog.empty?
      UI.user_error!("#{changelog_path} is empty. Write this build's TestFlight release notes before running `make beta`.")
    end

    build_ipa

    upload_to_testflight(
      api_key: api_key,
      ipa: "#{OUTPUT_DIRECTORY}/Cairn.ipa",
      skip_waiting_for_build_processing: false,
      distribute_external: false,
      notify_external_testers: false,
      changelog: changelog
    )
    UI.success "🚀 Uploaded to TestFlight"
  end

  desc "List recent TestFlight builds and their processing state"
  lane :status do
    app_store_connect_api_key(
      key_id:       ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id:    ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"]
    )
    app = Spaceship::ConnectAPI::App.all.find { |a| a.bundle_id == "app.cairn.ios" }
    UI.user_error!("App app.cairn.ios not visible to API key") unless app
    builds = Spaceship::ConnectAPI::Build.all(
      app_id: app.id,
      sort: "-uploadedDate",
      limit: 5,
      includes: "preReleaseVersion,buildBetaDetail"
    )
    builds.each do |b|
      ver = b.pre_release_version&.version || "?"
      detail = b.build_beta_detail
      ext_state = detail&.external_build_state || "n/a"
      int_state = detail&.internal_build_state || "n/a"
      UI.message "build #{b.version} (#{ver}) — processing=#{b.processing_state} internal=#{int_state} external=#{ext_state} uploaded=#{b.uploaded_date}"
    end
  end

  desc "Tag the commit that corresponds to the App Store's live release"
  lane :tag_live_release do |options|
    # Queries App Store Connect for the version currently in the
    # READY_FOR_SALE state, reads its build number + uploaded date,
    # then locates the git commit that was HEAD at that upload time
    # and creates an annotated tag `v<marketing-version>` against it.
    #
    # Why uploaded date rather than `Bump to build N` commit subjects:
    # `fastlane beta` internally bumps CFBundleVersion before each
    # upload (via `build_ipa` → `bump_build`), and re-runs of the
    # lane silently auto-bump without committing. So a build number
    # on TestFlight has no guaranteed matching git commit — but the
    # upload's wall-clock timestamp does map to a single git HEAD,
    # which is the truthful "code state at the moment of upload."
    #
    # The lane is idempotent on the tag name: if `v<version>` already
    # exists it logs and exits without re-tagging. Pass `push:true`
    # to also push the tag to origin (default false — pushing is
    # visible to others and worth a confirmation step).
    push_tag = options[:push] == true || options[:push] == "true"

    app_store_connect_api_key(
      key_id:       ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id:    ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"]
    )
    app = Spaceship::ConnectAPI::App.all.find { |a| a.bundle_id == APP_IDENTIFIER }
    UI.user_error!("App #{APP_IDENTIFIER} not visible to API key") unless app

    # `sort` isn't accepted by this endpoint; rely on the
    # READY_FOR_SALE filter and grab the unique live version (Apple
    # only marks one App Store row READY_FOR_SALE at a time).
    versions = app.get_app_store_versions(
      includes: "build",
      limit: 10
    )
    live = versions.find { |v| v.app_store_state == "READY_FOR_SALE" }
    unless live
      states = versions.map { |v| "#{v.version_string}=#{v.app_store_state}" }.join(", ")
      UI.user_error!("No App Store version in READY_FOR_SALE state. Recent: #{states}")
    end

    marketing = live.version_string
    build_obj = live.build
    UI.user_error!("Live version #{marketing} has no selected build") unless build_obj
    build_number = build_obj.version
    upload_iso = build_obj.uploaded_date
    UI.user_error!("Live build #{build_number} has no uploaded_date — can't time-correlate") unless upload_iso
    tag_name = "v#{marketing}"

    UI.message "Live App Store version: #{marketing} (build #{build_number}, uploaded #{upload_iso})"

    # Existing-tag short circuit. `git rev-parse --verify` exits non-
    # zero when the tag is missing — we capture without raising.
    # `^{commit}` peels through the tag object to its underlying
    # commit so the displayed SHA matches what `git log` would show.
    existing = `git rev-parse --verify --quiet #{tag_name}^{commit}`.strip
    if !existing.empty?
      UI.message "Tag #{tag_name} already exists at #{existing[0..7]} — skipping."
      next
    end

    # Find the commit that was HEAD at the moment of upload. `--before`
    # accepts ISO-8601, which is what Spaceship hands back. `-1`
    # caps the listing at the single closest predecessor.
    sha = `git log --all --before='#{upload_iso}' --format='%H' -1`.strip
    UI.user_error!("Couldn't locate a commit before #{upload_iso}.") if sha.empty?

    summary = `git log -1 --format='%h %s' #{sha}`.strip
    UI.message "Tagging #{tag_name} at #{sha[0..7]} — #{summary}"
    sh("git tag -a #{tag_name} -m 'App Store release #{marketing} (build #{build_number}, uploaded #{upload_iso})' #{sha}")
    UI.success "🏷  Tagged #{tag_name} locally"

    if push_tag
      sh("git push origin #{tag_name}")
      UI.success "📤 Pushed #{tag_name} to origin"
    else
      UI.important "Run `git push origin #{tag_name}` to publish the tag (or re-run with push:true)."
    end
  end

  desc "Push App Store listing metadata + screenshots without rebuilding"
  lane :metadata do
    # Pushes everything in fastlane/metadata/ + the curated screenshot
    # set in fastlane/upload-screenshots/ to ASC's App Store Information
    # page. Doesn't touch the binary, doesn't submit for review. Use
    # after `make beta` has uploaded an IPA, when you want to populate
    # description/keywords/screenshots in one shot instead of copy-
    # pasting from `docs/app-store-metadata.md`.
    api_key = app_store_connect_api_key(
      key_id:       ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id:    ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"]
    )

    # Re-curate the upload set every push so any tweaks to the source
    # screenshots in fastlane/screenshots/ propagate. Cheap (just file
    # copies) and keeps fastlane/upload-screenshots/ as a derived
    # artifact rather than a hand-maintained one.
    sh("../scripts/curate-screenshots.sh")

    upload_to_app_store(
      api_key:                          api_key,
      skip_binary_upload:               true,
      skip_metadata:                    false,
      skip_screenshots:                 false,
      # Curated 4-shot upload set (alternating Light/Dark across the
      # main screens) lives here. Fastlane's `screenshots_path` points
      # at the directory ABOVE the locale folders, so we hand it the
      # parent dir (it'll find `en-US/` underneath).
      screenshots_path:                 "./fastlane/upload-screenshots",
      force:                            true,    # don't open the HTML preview, just push
      precheck_include_in_app_purchases: false,
      submit_for_review:                false,
      automatic_release:                false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
    UI.success "📝 Metadata + screenshots pushed to App Store Connect"
    UI.important "⚠️  Privacy labels and age-rating questionnaire still need to be filled out manually in ASC — fastlane doesn't fully automate those."
  end

  desc "Upload to App Store"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id:       ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id:    ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"]
    )

    build_ipa

    upload_to_app_store(
      api_key:                          api_key,
      force:                            true,
      skip_metadata:                    false,
      skip_screenshots:                 true,    # screenshots managed manually for now
      precheck_include_in_app_purchases: false,
      ipa:                              "#{OUTPUT_DIRECTORY}/Cairn.ipa",
      submit_for_review:                false,
      automatic_release:                false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
    UI.success "🎉 Uploaded to App Store Connect"
    UI.important "⚠️  Submit for review in App Store Connect when ready."
  end

  desc "Submit the already-uploaded build for App Store review — end-to-end via fastlane.\nPushes metadata (incl. metadata/en-US/release_notes.txt = the \"What's New\" field),\nattaches the latest uploaded build for this marketing version, and submits for review.\nRun AFTER `make beta` has uploaded the release build.\nUsage: bundle exec fastlane submit            # submit, release manually after approval\n       bundle exec fastlane submit auto_release:true   # auto-release once approved"
  lane :submit do |options|
    api_key = app_store_connect_api_key(
      key_id:       ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id:    ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"]
    )

    # Marketing version from the same source of truth the bump lanes use.
    version = File.read(PROJECT_YML).match(/CFBundleShortVersionString: "([^"]+)"/)[1]
    auto_release = [true, "true"].include?(options[:auto_release])

    # Guard: the "What's New" must be real. release_notes.txt is gitignored
    # and easy to forget; refuse to submit stale/empty notes.
    notes_path = File.join(__dir__, "metadata", "en-US", "release_notes.txt")
    UI.user_error!("Missing #{notes_path} — write the version's \"What's New\" first.") unless File.exist?(notes_path)
    UI.user_error!("#{notes_path} is empty.") if File.read(notes_path).strip.empty?

    UI.message "Submitting App Store version #{version} for review (auto_release=#{auto_release})…"

    upload_to_app_store(
      api_key:                          api_key,
      app_version:                      version,
      skip_binary_upload:               true,    # build already uploaded by `beta`; just attach it
      skip_metadata:                    false,   # push release_notes.txt as "What's New" + the rest of metadata/
      skip_screenshots:                 true,    # refresh those separately with `make metadata`
      force:                            true,    # don't open the HTML preview, just push
      precheck_include_in_app_purchases: false,
      submit_for_review:                true,
      automatic_release:                auto_release,
      submission_information: {
        add_id_info_uses_idfa:                       false,
        export_compliance_uses_encryption:           false,  # matches ITSAppUsesNonExemptEncryption=false
        content_rights_contains_third_party_content: false
      }
    )
    UI.success "🚀 Submitted version #{version} for App Store review"
    UI.important "Note: privacy nutrition labels + age rating live in ASC and fastlane can't fully set them. They carry over from the prior version, so a x.y.z update submits clean once 0.4.0 has them."
    UI.important "skip_metadata:false pushes the WHOLE metadata/ folder — keep it the source of truth (don't hand-edit those fields in ASC)."
  end

  desc "Capture App Store + README screenshots"
  # Delegates to scripts/capture-screenshots.sh because fastlane's
  # `capture_screenshots` builds its xcodebuild `-destination` from
  # simctl's short-form iOS version label ("iOS 26.4") but recent
  # xcodebuild insists on the full build string ("OS:26.4.1") for
  # the same simulator runtime. The shell script sidesteps this by
  # resolving each simulator by UDID, then post-processes the output
  # into the same fastlane/screenshots/<locale>/ layout.
  lane :screenshots do
    # `sh` runs from fastlane/; script self-locates to iOS/.
    sh("../scripts/capture-screenshots.sh")
    # Re-curate the upload set so the dirs stay in sync. Cheap; keeps
    # `fastlane/upload-screenshots/` ready for `make metadata` without
    # a separate step.
    sh("../scripts/curate-screenshots.sh")
    UI.success "📸 Screenshots captured under fastlane/screenshots/ and curated upload set under fastlane/upload-screenshots/"
  end

  desc "Setup certificates and provisioning profiles via match"
  lane :setup_certificates do
    match(type: "appstore", app_identifier: APP_IDENTIFIER, readonly: false)
  end

  desc "Sync certificates (readonly — for CI / fresh machines)"
  lane :sync_certificates do
    match(type: "appstore", app_identifier: APP_IDENTIFIER, readonly: true)
  end

  # ============================================================================
  # ERROR HANDLING
  # ============================================================================

  error do |lane, exception|
    UI.error "❌ Error in lane #{lane}: #{exception.message}"
  end
end
