# Copy this file to `.env` in the project root and fill in your values.
# `.env` is gitignored; never commit credentials.

# Base URL of your Immich server. Trailing slash and /api suffix are both
# optional — the CLI normalizes either form.
IMMICH_URL=https://photos.example.com

# API key generated in the Immich web UI under Account Settings → API Keys.
# Recommended scopes for cairn:
#   asset.read       — list your assets and their checksums
#   asset.delete     — move assets to trash and restore from trash
#   tag.create       — create per-run breadcrumb tags
#   tag.asset        — attach tags to assets
#   tag.read         — required for `cairn history` and `cairn restore --file-name-matches`
IMMICH_API_KEY=replace-me
